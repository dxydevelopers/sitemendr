# Database Configuration
DATABASE_URL="postgresql://username:password@hostname:port/database?pgbouncer=true&sslmode=require&connection_limit=20&pool_timeout=30"
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourAppName

PORT=5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Groq Configuration (Fallback)
GROQ_API_KEY=your_groq_api_key_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
ADMIN_EMAIL=admin@sitemendr.com
EMAIL_TRANSPORT=log
EMAIL_FROM="Sitemendr <no-reply@sitemendr.com>"
RESEND_API_KEY=your_resend_api_key_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_VERIFY_ON_START=true
EMAIL_ALLOW_INSECURE=false

# Domains
MAIN_DOMAIN=sitemendr.com
API_DOMAIN=api.sitemendr.com

# Paystack Configuration
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
PAYSTACK_CURRENCY=NGN

# Infrastructure & Automation
DISABLE_AUTOMATION=false
SSL_ENABLED=true
CLOUDFLARE_API_TOKEN=your_cloudflare_token_for_dns_automation
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
INFRA_IP=your_infrastructure_public_ip
INFRA_CNAME=nodes.sitemendr.com

# Deployment Providers
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_vercel_team_id
NETLIFY_TOKEN=your_netlify_token
NETLIFY_SITE_ID=your_netlify_site_id
DEPLOYMENT_PROVIDER=local # or vercel, netlify

# Security
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880  # 5MB
UPLOAD_PATH=./uploads

# Analytics
GOOGLE_ANALYTICS_ID=your_ga_tracking_id_here



