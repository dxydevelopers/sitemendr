{
    "name":  "sitemendr-backend",
    "version":  "1.0.0",
    "main":  "server.js",
    "scripts":  {
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "test:coverage":  "vitest run --coverage",
                    "test-api":  "node test-api.js",
                    "start":  "node server.js",
                    "dev":  "nodemon server.js",
                    "build:ts":  "tsc",
                    "type-check":  "tsc --noEmit",
                    "db:generate": "prisma generate",
                    "postinstall": "prisma generate"
                },
    "keywords":  [
                     "sitemendr",
                     "api",
                     "backend"
                 ],
    "author":  "Sitemendr Team",
    "license":  "ISC",
    "description":  "Sitemendr Backend API - web development platform",
