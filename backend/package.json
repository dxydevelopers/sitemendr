                         "compression":  "^1.8.1",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.5.0",
                         "express":  "^5.2.1",
                         "express-rate-limit":  "^8.2.1",
                         "express-validator":  "^7.3.1",
                         "groq-sdk":  "^0.37.0",
                         "helmet":  "^8.1.0",
                         "js-yaml":  "^4.1.0",
                         "jsonwebtoken":  "^9.0.2",
                         "multer":  "^2.0.2",
                         "nodemailer":  "^6.10.1",
                         "openai":  "^4.0.0",
                         "pdfkit":  "^0.17.0",
